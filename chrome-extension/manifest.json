{
  "manifest_version": 3,
  "name": "📡 Livestream Radar",
  "version": "3.1.0",
  "description": "Captures Facebook Live comments, sends to Radar backend via WebSocket, and injects tier badges + quick-reply buttons.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://web.facebook.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Livestream Radar",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}